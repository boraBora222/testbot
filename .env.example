# --- General Bot Settings ---
BOT_NAME=reply_bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# --- MongoDB Settings ---
MONGO_URI=mongodb://mongo:27017/
MONGO_DB_NAME=reply_db

# --- Redis Settings ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
BROADCAST_QUEUE_NAME=reply_bot_broadcast_queue
ORDER_STATUS_QUEUE_NAME=bot:order_status
NOTIFY_MANAGERS_QUEUE_NAME=bot:notify_managers

# --- Web Admin Settings ---
WEB_PORT=8071
WEB_USERNAME=admin
WEB_PASSWORD=password
WEB_BASE_URL=http://localhost:8071
FRONT_BASE_URL=http://localhost:5138

# --- Website Auth Settings ---
AUTH_COOKIE_NAME=cryptodeal_session
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_VERIFICATION_CODE_TTL_MINUTES=10
AUTH_RESET_CODE_TTL_MINUTES=10
AUTH_VERIFICATION_CODE_LENGTH=6
AUTH_RESET_CODE_LENGTH=6
AUTH_MAX_CODE_ATTEMPTS=5

# --- SMTP Settings ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true

# --- Demo Bot Settings ---
MASTER_USER_IDS=12345678,98765432
DEMO_MODE=true
DEFAULT_FEE_PERCENT=0.5
MIN_EXCHANGE_AMOUNT_RUB=10000
MAX_EXCHANGE_AMOUNT_RUB=10000000
FSM_TIMEOUT_MINUTES=30
RATES_USDT_RUB=92.5000
RATES_BTC_RUB=8500000.0000
RATES_ETH_RUB=250000.0000
RATES_USDT_BTC=0.0000109
RATES_BTC_USDT=91743.1193
RATES_ETH_USDT=2702.7027
LOG_LEVEL=INFO

# --- Optional legacy queues ---
# REDIS_QUEUE_NAME=reply_bot_queue
